        {
          "rawSql": "SELECT collected_at AS time, value AS \"Used Memory\", device_name AS metric FROM metrics WHERE category = 'HARDWARE' AND metric_name LIKE '%used-mem%' AND DATE(collected_at) = (SELECT sim_date FROM simulation_state LIMIT 1) AND device_name IN (${device:sqlstring}) ORDER BY collected_at;",
          "format": "time_series"
